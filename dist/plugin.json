{
  "type": "app",
  "name": "Template Hub",
  "id": "greg00r-templatehub-app",
  "info": {
    "description": "A Grafana Template Hub for publishing, reviewing, and importing reusable dashboards within your organization.",
    "author": {
      "name": "Greg00r",
      "url": ""
    },
    "keywords": ["template-hub", "dashboard", "templates", "gallery"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [],
    "screenshots": [],
    "version": "1.0.4",
    "updated": "2026-04-19"
  },
  "includes": [
    {
      "type": "page",
      "name": "Template Hub",
      "path": "/a/greg00r-templatehub-app",
      "role": "Viewer",
      "action": "greg00r-templatehub-app.templates:read",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "name": "Upload Template",
      "path": "/a/greg00r-templatehub-app/upload",
      "role": "Viewer",
      "action": "greg00r-templatehub-app.templates:publish",
      "addToNav": false
    },
    {
      "type": "page",
      "name": "Review Templates",
      "path": "/a/greg00r-templatehub-app/review",
      "role": "Viewer",
      "action": "greg00r-templatehub-app.templates:review",
      "addToNav": false
    }
  ],
  "roles": [
    {
      "role": {
        "name": "Template Hub Viewer",
        "description": "Browse approved dashboard templates in Template Hub.",
        "permissions": [
          {
            "action": "greg00r-templatehub-app.templates:read"
          }
        ]
      },
      "grants": ["Viewer"]
    },
    {
      "role": {
        "name": "Template Hub Publisher",
        "description": "Submit dashboard templates to Template Hub for admin review.",
        "permissions": [
          {
            "action": "greg00r-templatehub-app.templates:publish"
          }
        ]
      },
      "grants": ["Editor"]
    },
    {
      "role": {
        "name": "Template Hub Reviewer",
        "description": "Review, approve, delete, and initialize Template Hub templates.",
        "permissions": [
          {
            "action": "greg00r-templatehub-app.templates:review"
          },
          {
            "action": "greg00r-templatehub-app.templates:approve"
          },
          {
            "action": "greg00r-templatehub-app.templates:delete"
          },
          {
            "action": "greg00r-templatehub-app.templates:initialize"
          }
        ]
      },
      "grants": ["Admin"]
    }
  ],
  "iam": {
    "permissions": [
      {
        "action": "users.permissions:read",
        "scope": "users:*"
      }
    ]
  },
  "backend": true,
  "autoEnabled": true,
  "executable": "gpx_templatehub",
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "grafanaVersion": "13.x",
    "plugins": []
  }
}
